include LICENSE
include README.md
include pyproject.toml

recursive-include algo_a *.py
recursive-include algo_b *.py
recursive-include config *.py
recursive-include platform_mac *.py
recursive-include platform_win *.py
recursive-include shared *.py
recursive-include utils *.py
recursive-include weclaw_cli *.py
recursive-include weclaw_cli bin/*

prune tests
prune scripts
prune npm
prune openclaw_skill
prune sample_data
prune output
prune .cursor
prune .venv
prune build
prune dist
prune weclaw_cua.egg-info

global-exclude __pycache__ *.py[cod] .DS_Store
